<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= product.name %> - Product Details</title>
  <link rel="stylesheet" href="/styles.css"> <!-- make sure this path is correct -->
  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 2rem;
      background: #f9f9f9;
    }
    .container {
      display: flex;
      gap: 2rem;
      background: white;
      padding: 2rem;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      max-width: 900px;
      margin: auto;
    }
    .product-image img {
      width: 300px;
      border-radius: 10px;
    }
    .product-details h1 {
      margin-bottom: 1rem;
    }
